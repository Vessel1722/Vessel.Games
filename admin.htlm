<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>VesselGames Admin · Supabase</title>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <style>
    :root{--primary:#8a2be2;--accent:#00ffcc;--token:#ff007f;--bg:#07070a;--card:#12121a;--text:#fff;--dim:#a0a0b0;--line:rgba(255,255,255,.1)}
    *{box-sizing:border-box;margin:0;padding:0} body{font-family:system-ui,-apple-system,Segoe UI,Montserrat,sans-serif;background:radial-gradient(circle at 15% 0%,rgba(138,43,226,.18),transparent 32%),#07070a;color:#fff;min-height:100vh;padding-top:82px}.top{position:fixed;inset:0 0 auto 0;height:76px;background:rgba(7,7,10,.98);border-bottom:1px solid var(--line);display:flex;align-items:center;justify-content:space-between;gap:12px;padding:12px 5%;z-index:10;box-shadow:0 14px 38px rgba(0,0,0,.55)}.brand{display:flex;align-items:center;gap:10px;color:#fff;text-decoration:none;font-weight:900;letter-spacing:.08em}.mark{width:44px;height:44px;border-radius:14px;display:grid;place-items:center;background:linear-gradient(135deg,var(--primary),var(--accent));font-weight:900}.brand span span{color:var(--accent)}.nav{display:flex;gap:8px}.nav a,.nav button,.btn{border:0;border-radius:999px;padding:11px 16px;background:linear-gradient(135deg,var(--primary),#b45cff);color:#fff;font-weight:900;text-decoration:none;cursor:pointer}.nav button{background:rgba(255,0,127,.16);border:1px solid rgba(255,0,127,.3)}.wrap{max-width:1180px;margin:0 auto;padding:28px 5% 70px}.title{text-align:center;font-size:clamp(1.6rem,5vw,2.5rem);margin-bottom:22px;text-transform:uppercase}.card{background:linear-gradient(180deg,rgba(255,255,255,.055),rgba(255,255,255,.025)),var(--card);border:1px solid var(--line);border-radius:22px;padding:20px;margin:0 0 18px;box-shadow:0 18px 45px rgba(0,0,0,.28)}.card h2{margin-bottom:12px}.muted{color:var(--dim);line-height:1.55;margin-bottom:12px}.grid{display:grid;grid-template-columns:1fr 1fr;gap:13px}.field{display:grid;gap:7px;margin:8px 0}.full{grid-column:1/-1}label{color:var(--dim);font-size:.78rem;text-transform:uppercase;font-weight:900}input,select,textarea{width:100%;background:#08080d;border:1px solid #2d2d3d;color:#fff;border-radius:13px;padding:12px;font:inherit}textarea{min-height:86px;resize:vertical}.json{font-family:Consolas,monospace;min-height:130px}input:focus,textarea:focus,select:focus{outline:none;border-color:var(--primary);box-shadow:0 0 0 3px rgba(138,43,226,.16)}.actions{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px}.btn.secondary{background:rgba(255,255,255,.06);border:1px solid var(--line);box-shadow:none}.btn.danger{background:#d9365e}.list{display:grid;gap:10px}.row{display:grid;grid-template-columns:1.2fr .7fr .5fr auto;gap:10px;align-items:center;background:rgba(255,255,255,.035);border:1px solid var(--line);border-radius:14px;padding:12px}.row strong{display:block}.row small{color:var(--dim)}.pill{display:inline-flex;border:1px solid var(--line);padding:5px 9px;border-radius:999px;color:var(--accent);font-weight:900;font-size:.76rem}.hide{display:none!important}.msg{margin-top:10px;color:var(--accent);font-weight:700}.toolbar{display:flex;justify-content:space-between;gap:12px;align-items:center;margin-bottom:12px}.search{max-width:360px}@media(max-width:760px){body{padding-top:74px}.top{height:70px;padding:10px 4%}.brand span{font-size:.8rem}.mark{width:40px;height:40px}.nav a,.nav button{padding:9px 10px;font-size:.72rem}.grid,.row{grid-template-columns:1fr}.wrap{padding:22px 4% 50px}.toolbar{flex-direction:column;align-items:stretch}.btn{width:100%}.actions{flex-direction:column}}
  </style>
</head>
<body>
  <div class="top"><a class="brand" href="index.html"><b class="mark">V</b><span>VESSEL<span>ADMIN</span></span></a><div class="nav"><a href="index.html">Ver tienda</a><button onclick="logout()">Salir</button></div></div>
  <main class="wrap">
    <h1 class="title">Panel real Supabase</h1>
    <section class="card" id="loginBox"><h2>Entrar</h2><p class="muted">Usa el correo y contraseña que creaste en Supabase Authentication.</p><div class="grid"><div class="field"><label>Correo</label><input id="email" type="email" placeholder="example@gmail.com"></div><div class="field"><label>Contraseña</label><input id="password" type="password"></div></div><button class="btn" onclick="login()">Entrar</button><p class="msg" id="loginMsg"></p></section>
    <div id="adminContent" class="hide">
      <section class="card"><h2>Configuración de página</h2><div class="grid"><div class="field"><label>Badge portada</label><input id="hero_badge"></div><div class="field"><label>WhatsApp con lada</label><input id="whatsapp_number"></div><div class="field"><label>Telegram URL</label><input id="telegram_url"></div><div class="field"><label>Color principal</label><input id="primary_color"></div><div class="field full"><label>Título HTML portada</label><textarea id="hero_title_html"></textarea></div><div class="field full"><label>Subtítulo portada</label><textarea id="hero_subtitle"></textarea></div><div class="field full"><label>Garantía</label><textarea id="guarantee_text"></textarea></div></div><button class="btn" onclick="saveSettings()">Guardar configuración</button><p class="msg" id="settingsMsg"></p></section>
      <section class="card" id="formCard"><h2 id="formTitle">Agregar producto</h2><input type="hidden" id="p_id"><div class="grid"><div class="field"><label>Nombre</label><input id="p_name"></div><div class="field"><label>Categoría</label><select id="p_category"><option value="gaming">Gaming</option><option value="streaming">Streaming</option><option value="cuentas">Cuentas</option><option value="software">Software</option><option value="redes">Redes</option></select></div><div class="field"><label>Imagen URL</label><input id="p_image_url"></div><div class="field"><label>Badge</label><input id="p_badge" placeholder="Oferta limitada"></div><div class="field"><label>Orden</label><input id="p_sort_order" type="number" value="100"></div><div class="field"><label>Activo</label><select id="p_active"><option value="true">Visible</option><option value="false">Oculto</option></select></div><div class="field"><label>Tipo</label><select id="p_card_type"><option value="normal">Normal</option><option value="retro">Selector juegos retro</option></select></div><div class="field"><label>Mensaje WhatsApp</label><input id="p_whatsapp_text"></div><div class="field full"><label>Nota de entrega</label><textarea id="p_delivery_note"></textarea></div><div class="field full"><label>Opciones JSON</label><textarea id="p_options" class="json">[{"label":"1 Mes","price_mxn":100}]</textarea></div></div><div class="actions"><button class="btn" onclick="saveProduct()">Guardar producto</button><button class="btn secondary" onclick="clearForm()">Limpiar</button></div><p class="msg" id="productMsg"></p></section>
      <section class="card"><div class="toolbar"><h2>Productos</h2><input class="search" id="search" placeholder="Buscar producto..." oninput="renderProducts()"></div><div class="list" id="productsList"></div></section>
    </div>
  </main>
<script>
const SUPABASE_URL='https://cdfyzmwccdqmljwhqnjm.supabase.co';
const SUPABASE_KEY='sb_publishable_cl0-ImakwDc9X1ZcNiJPlg_7J3L5VUm';
const db=supabase.createClient(SUPABASE_URL,SUPABASE_KEY); let allProducts=[];
const $=id=>document.getElementById(id); const val=id=>$(id)?.value ?? '';
function msg(id,t){const e=$(id); if(e){e.textContent=t; setTimeout(()=>e.textContent='',3500)}}
async function login(){const {error}=await db.auth.signInWithPassword({email:val('email'),password:val('password')}); if(error){msg('loginMsg','Error: '+error.message);return} await init();}
async function logout(){await db.auth.signOut(); location.reload();}
async function init(){const {data:{session}}=await db.auth.getSession(); if(!session){$('loginBox').classList.remove('hide');$('adminContent').classList.add('hide');return} $('loginBox').classList.add('hide');$('adminContent').classList.remove('hide'); await loadSettings(); await loadProducts();}
async function loadSettings(){const {data,error}=await db.from('site_settings').select('*').eq('id',1).maybeSingle(); if(error){msg('settingsMsg',error.message);return} const s=data||{}; ['hero_badge','hero_title_html','hero_subtitle','whatsapp_number','telegram_url','primary_color','guarantee_text'].forEach(k=>{if($(k))$(k).value=s[k]||''});}
async function saveSettings(){const payload={id:1,hero_badge:val('hero_badge'),hero_title_html:val('hero_title_html'),hero_subtitle:val('hero_subtitle'),whatsapp_number:val('whatsapp_number'),telegram_url:val('telegram_url'),primary_color:val('primary_color'),guarantee_text:val('guarantee_text'),updated_at:new Date().toISOString()}; const {error}=await db.from('site_settings').upsert(payload); msg('settingsMsg',error?('Error: '+error.message):'Configuración guardada.');}
async function loadProducts(){const {data,error}=await db.from('products').select('*').order('sort_order',{ascending:true}).order('name',{ascending:true}); if(error){alert(error.message);return} allProducts=data||[]; renderProducts();}
function renderProducts(){const q=val('search').toLowerCase(); const list=$('productsList'); list.innerHTML=''; allProducts.filter(p=>(p.name||'').toLowerCase().includes(q)||(p.category||'').toLowerCase().includes(q)).forEach(p=>{const div=document.createElement('div'); div.className='row'; const first=(Array.isArray(p.options)&&p.options[0])?`$${p.options[0].price_mxn} MXN`:'Cotizar'; div.innerHTML=`<div><strong>${escapeHtml(p.name)}</strong><small>${escapeHtml(p.delivery_note||'')}</small></div><span class="pill">${escapeHtml(p.category)}</span><span>${p.active?'Visible':'Oculto'} · ${first}</span><div class="actions"><button class="btn secondary" onclick="editProduct(${p.id})">Editar</button><button class="btn danger" onclick="deleteProduct(${p.id})">Borrar</button></div>`; list.appendChild(div);});}
function escapeHtml(s){return String(s??'').replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));}
function editProduct(id){const p=allProducts.find(x=>x.id===id); if(!p)return; $('formTitle').textContent='Editando: '+p.name; $('p_id').value=p.id; ['name','category','image_url','badge','sort_order','card_type','whatsapp_text','delivery_note'].forEach(k=>{const el=$('p_'+k); if(el)el.value=p[k]??''}); $('p_active').value=String(!!p.active); $('p_options').value=JSON.stringify(p.options||[],null,2); $('formCard').scrollIntoView({behavior:'smooth',block:'start'});}
function clearForm(){$('formTitle').textContent='Agregar producto'; ['p_id','p_name','p_image_url','p_badge','p_whatsapp_text','p_delivery_note'].forEach(id=>$(id).value=''); $('p_category').value='gaming'; $('p_sort_order').value='100'; $('p_card_type').value='normal'; $('p_active').value='true'; $('p_options').value='[{"label":"1 Mes","price_mxn":100}]';}
async function saveProduct(){let options=[]; try{options=JSON.parse(val('p_options')||'[]'); if(!Array.isArray(options)) throw new Error('Opciones debe ser una lista');}catch(e){msg('productMsg','JSON inválido: '+e.message);return} const payload={name:val('p_name'),category:val('p_category'),image_url:val('p_image_url'),badge:val('p_badge'),delivery_note:val('p_delivery_note'),whatsapp_text:val('p_whatsapp_text'),options,active:val('p_active')==='true',sort_order:parseInt(val('p_sort_order')||'100',10),card_type:val('p_card_type')||'normal',updated_at:new Date().toISOString()}; const id=val('p_id'); let res; if(id) res=await db.from('products').update(payload).eq('id',id); else res=await db.from('products').insert(payload); if(res.error){msg('productMsg','Error: '+res.error.message);return} msg('productMsg','Producto guardado.'); clearForm(); await loadProducts();}
async function deleteProduct(id){if(!confirm('¿Borrar este producto?'))return; const {error}=await db.from('products').delete().eq('id',id); if(error) alert(error.message); else loadProducts();}
document.addEventListener('DOMContentLoaded',init);
</script>
</body></html>
